generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum GameStatus {
  OWNED
  WISHLIST
  PLAYED
}

model Game {
  id                  String      @id @default(cuid())
  boardlifeId         String      @unique
  title               String
  englishTitle        String      @default("")
  year                Int?
  image               String?
  sourceUrl           String
  minPlayers          Int?
  maxPlayers          Int?
  bestPlayers         Int?
  recommendedPlayers  String?
  minAge              Int?
  playTime            String?
  complexity          Float?
  boardlifeRating     Float?
  languageDependency  String?
  sourceFetchedAt     DateTime?
  personalRating      Float?
  review              String?
  plays               Int         @default(0)
  status              GameStatus  @default(OWNED)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  tags                GameTag[]
  photos              GamePhoto[]
  videos              GameVideo[]
  playlistItems       PlaylistItem[]

  @@index([createdAt])
}

model Playlist {
  id          String         @id @default(cuid())
  shareId     String         @unique @default(cuid())
  shareCode   String?        @unique
  title       String
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  items       PlaylistItem[]

  @@index([createdAt])
}

model PlaylistItem {
  playlistId String
  gameId     String
  position   Int
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@id([playlistId, gameId])
  @@index([playlistId, position])
  @@index([gameId])
}

model GameVideo {
  id          String   @id @default(cuid())
  youtubeId   String
  url         String
  title       String
  thumbnail   String?
  channelName String?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  gameId      String
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, youtubeId])
  @@index([gameId, createdAt])
}

model GamePhoto {
  id        String   @id @default(cuid())
  url       String
  pathname  String   @unique
  caption   String?
  createdAt DateTime @default(now())
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId, createdAt])
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  games     GameTag[]
}

model GameTag {
  gameId String
  tagId  String
  game   Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([gameId, tagId])
  @@index([tagId])
}
